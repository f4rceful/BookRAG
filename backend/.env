# URL Ollama (по умолчанию локальный)
OLLAMA_BASE_URL=http://localhost:11434

# Название модели Ollama (должна быть заранее скачана: ollama pull название модели)
MODEL_NAME=qwen2.5:3b

# Модель для эмбеддингов (скачается автоматически с HuggingFace)
EMBEDDING_MODEL=BAAI/bge-m3

# Папка для хранения векторной базы ChromaDB
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Параметры нарезки текста (влияют на качество поиска)
CHUNK_SIZE=800
CHUNK_OVERLAP=300
INDEX_BATCH_SIZE=100


CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
DOCS_ENABLED=True